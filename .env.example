# Supabase (required for persistent incremental data storage)
# Create free project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: public anon key (read-only fallback)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
